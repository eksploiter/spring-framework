<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
    
<mapper namespace="com.ssafy.shopApp.model.dao.IUserDAO">
	
	<select id="login">
		select name from userinfo where userid=#{userId} and password=#{password}
	</select>
	
</mapper>

